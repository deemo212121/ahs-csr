# Supabase project credentials for YOUR website database.
# Customer accounts, verification queue, chat, notifications, and local request records stay here.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only Supabase key for YOUR website API routes.
# Never expose this in client/browser components.
SUPABASE_SERVICE_ROLE_KEY=

# Firebase client config, used by the browser staff login page.
# Staff authorization/profile data is loaded from ER_PROFILES_TABLE by firebase_uid.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase server config, used by API routes to verify Firebase staff ID tokens.
# FIREBASE_PROJECT_ID alone supports verification-only use.
# Option A: optionally paste a service account JSON for privileged Admin API operations.
FIREBASE_SERVICE_ACCOUNT_JSON=

# Option B: optionally use individual service-account fields instead of JSON.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Optional: local-only testing login while Firebase/Supabase are not configured.
# Leave blank/false for production.
NEXT_PUBLIC_ENABLE_TEST_LOGIN=
ENABLE_TEST_LOGIN=

# Ticket database mode.
# local = customer requests are verified in YOUR Supabase first.
# er_supabase = customer requests are saved/verified in ER public.portal_service_requests, then approved rows create ER public.tickets.
TICKET_DATABASE_MODE=er_supabase

# Optional ER/second TypeScript project API sync.
# Use this only if the ER developer gives you an API endpoint instead of direct Supabase access.
ER_SYNC_API_URL=
ER_SYNC_API_KEY=

# Direct server-side connection to THEIR ER Supabase project.
# Never expose the service role key in browser/client components.
ER_SUPABASE_URL=
# Public key used with the short-lived authenticated staff JWT returned by the ER bridge.
ER_SUPABASE_ANON_KEY=
# ER-owned Firebase-to-Supabase token exchange endpoint. Never copy ER's JWT signing secret.
ER_SUPABASE_TOKEN_URL=
ER_SUPABASE_SERVICE_ROLE_KEY=
ER_SUPABASE_TICKETS_TABLE=tickets
ER_SUPABASE_CUSTOMERS_TABLE=customers
# Staff Ticket Request pages read live tickets from the ER table when ER Supabase is configured.
# Keep this as created_at unless the ER team wants newest by updated_at.
ER_TICKET_VIEW_ORDER_COLUMN=created_at
# Optional: leave blank to show all ER tickets. Fill only if ER wants one company filtered.
ER_TICKET_VIEW_COMPANY_ID=

# ER service area/city coverage source.
# Admin Cities and dashboard coverage cards read from this ER table in view-only mode.
ER_LOCATION_COVERAGE_TABLE=location_mgmt_coverage
# Optional: leave blank to use ER_DEFAULT_COMPANY_ID for coverage filtering.
ER_LOCATION_VIEW_COMPANY_ID=

# Required for new rows saved in ER public.portal_service_requests.
# The website no longer inserts approved requests into public.tickets; ER will post approved rows later.
ER_DEFAULT_COMPANY_ID=
ER_DEFAULT_CUSTOMER_ID=
ER_DEFAULT_TICKET_SOURCE=Customer Portal
ER_DEFAULT_WARRANTY=IW

# ER portal verification table. Run supabase/er_portal_service_requests_setup.sql in the ER database first.
ER_PORTAL_REQUESTS_TABLE=portal_service_requests

# ER activity log source.
# Admin Activity Logs and CSR Manager Activity Logs read from this ER table in view-only mode.
ER_TICKET_AUDIT_LOG_TABLE=ticket_audit_log
# ER staff profile source used for staff authorization and to turn
# ticket_audit_log.changed_by into name/email.
# Supported role mapping:
# ADMIN/SUPERADMIN -> admin; MANAGER/CSR Manager/Branch Manager -> csr_manager;
# Team Leader/TL -> team_leader; CSR/CSR Agent -> csr.
ER_PROFILES_TABLE=profiles

# Optional: maximum ER customers scanned for matching customer portal accounts by phone/email.
ER_CUSTOMER_MATCH_SCAN_LIMIT=10000
